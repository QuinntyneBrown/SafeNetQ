@startuml sequence-str-filing
title Compliance & Reporting -- STR Creation and Filing Flow

skinparam defaultFontSize 11
skinparam shadowing false
skinparam sequenceMessageAlign center
skinparam maxMessageSize 200

actor "Compliance Officer" as CO
participant "ComplianceController" as CC
participant "DetectionService" as DS
participant "StrService" as SS
participant "FintracExporter" as FE
database "PostgreSQL" as DB

== Alert Detection (automated) ==

participant "Event Bus" as Bus
Bus -> DS : TransactionCompleted\n{transactionId, amount, memberId}
DS -> DS : Evaluate against\nactive detection rules
alt Rule triggered (e.g. amount >= $10,000)
  DS -> DB : INSERT detection_alert\n(ruleId, transactionIds, severity)
  DS -> Bus : AlertCreated event
end

== Alert Review ==

CO -> CC : GET /api/v1/compliance/alerts\n?status=Pending
CC -> DS : GetAlertsAsync(filter)
DS -> DB : SELECT * FROM detection_alerts\nWHERE status = 'Pending'
DB --> DS : alerts[]
DS --> CC : alerts
CC --> CO : List of pending alerts

CO -> CC : Review alert details
CC -> DS : ReviewAlertAsync(alertId, Escalated)
DS -> DB : UPDATE detection_alerts\nSET status = 'Escalated'

== STR Creation ==

CO -> CC : POST /api/v1/compliance/strs\n{alertId, subjectMemberId,\ntransactionIds, indicators, narrative}
CC -> SS : CreateAsync(request)
SS -> DB : INSERT suspicious_transaction_report\n(status = Draft)
DB --> SS : STR record
SS --> CC : StrDto
CC --> CO : STR created (Draft)

== STR Review & Filing ==

CO -> CC : Review and update narrative
CO -> CC : PUT /api/v1/compliance/strs/{id}/file
CC -> SS : FileAsync(strId)

SS -> DB : SELECT str WHERE id = ?
DB --> SS : STR record

SS -> FE : ExportStrXmlAsync(str)
FE -> FE : Build FINTRAC-compliant\nXML document
FE --> SS : xmlBytes

SS -> DB : UPDATE str\nSET status = 'Filed',\nfiledAt = now()
DB --> SS : updated

SS -> DB : INSERT audit_log\n(actor=CO, action=STR_FILED,\ntarget=strId)

SS --> CC : Filed successfully
CC --> CO : STR filed with FINTRAC

@enduml
